{
  "manifest_version": 3,
  "name": "Sirch AI",
  "version": "1.0.0",
  "description": "Search the web, see real site previews, and get AI-powered summaries — all from your new tab.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "omnibox": {
    "keyword": "sirch"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": []
}
